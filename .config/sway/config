# Mod1 = alt, Mod4 = Super
set $mod Mod1
set $super Mod4

# Vim movement bindings
set $left h
set $down j
set $up k
set $right l

# Launcher
set $launcher wofi --show drun -I | xargs swaymsg exec --

set $wallpaper_dir $HOME/Pictures/Wallpapers
set $set_wallpaper \
	wallpaper=$(find $wallpaper_dir -type f | shuf -n 1) && \
	wal -qni "${wallpaper}" && \
	swaymsg output "*" background "${wallpaper}" fill

exec $set_wallpaper
exec pipewire
exec pipewire-pulse
include ~/.cache/wal/colors-sway

client.focused          $color14				$background	$foreground	$color7 	$foreground
client.focused_inactive $color3					$background	$foreground	$color8 	$color8
client.unfocused        $color1         $background	$foreground	$color2 	$color2
client.urgent           $color5         $background	$foreground	$color13 	$color6

default_border pixel 2
gaps outer 2
gaps inner 4

# Lock screen after 3 minutes of inactivity, turn off screen after 4
exec_always swayidle -w \
	timeout 180 'swaylock -f -c 000000' \
	timeout 240 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
	before-sleep 'swaylock -f -c 000000'

# Natural scrolling on touchpads
input type:touchpad {
	natural_scroll enabled
	scroll_factor 1
}

# Disable mouse acceleration
input type:pointer {
	accel_profile "flat"
	pointer_accel 0
}

floating_modifier $mod normal
# Status Bar
bar {
	position top
	swaybar_command waybar
}

include binds
include /etc/sway/config.d/*
